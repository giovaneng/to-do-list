        "format": "handlebars",
        "syntax": "mustache",
        "template": "<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Resultado do CEP</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 40px;\n      background: #f5f7fb;\n    }\n\n    h1 {\n      color: #1f2937;\n      margin-bottom: 20px;\n    }\n\n    .card {\n      background: #ffffff;\n      border-radius: 10px;\n      padding: 18px;\n      margin-bottom: 12px;\n      box-shadow: 0 2px 8px rgba(0,0,0,0.08);\n    }\n\n    .linha {\n      font-size: 16px;\n      color: #111827;\n      margin-bottom: 6px;\n    }\n\n    .label {\n      font-weight: bold;\n    }\n\n    .btn-container {\n      margin-top: 20px;\n    }\n\n    button {\n      padding: 10px;\n      font-size: 16px;\n      cursor: pointer;\n    }\n  </style>\n</head>\n<body>\n\n\n  {{#cepErro}}\n  <script>\n    alert(\"{{cepErro}}\");\n    window.location.href = \"/cep\";\n  </script>\n  {{/cepErro}}\n\n\n  {{^cepErro}}\n  <h1>Resultado do CEP</h1>\n\n  <div class=\"card\">\n    <div class=\"linha\"><span class=\"label\">CEP:</span> {{cepData.cep}}</div>\n    <div class=\"linha\"><span class=\"label\">Rua:</span> {{cepData.street}}</div>\n    <div class=\"linha\"><span class=\"label\">Bairro:</span> {{cepData.neighborhood}}</div>\n    <div class=\"linha\"><span class=\"label\">Cidade:</span> {{cepData.city}}</div>\n    <div class=\"linha\"><span class=\"label\">Estado:</span> {{cepData.state}}</div>\n  </div>\n\n  <div class=\"btn-container\">\n    <form action=\"/cep\" method=\"get\">\n      <button type=\"submit\">Voltar</button>\n    </form>\n  </div>\n  {{/cepErro}}\n\n</body>\n</html>",
