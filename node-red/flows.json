        "template": "<!DOCTYPE html>\n<html lang=\"pt-BR\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Buscar CEP</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 40px;\n      background: #f5f7fb;\n    }\n\n    .box {\n      background: #fff;\n      padding: 20px;\n      border-radius: 10px;\n      box-shadow: 0 2px 8px rgba(0,0,0,.08);\n      max-width: 500px;\n    }\n\n    input, button {\n      padding: 10px;\n      font-size: 16px;\n    }\n\n    input {\n      width: 250px;\n      margin-right: 8px;\n    }\n\n    button {\n      cursor: pointer;\n    }\n  </style>\n</head>\n<body>\n  <h1>Busca de CEP</h1>\n\n  <div class=\"box\">\n    <form action=\"/cep/search\" method=\"get\">\n      <input type=\"text\" name=\"cep\" placeholder=\"Digite o CEP\" maxlengh=\"9\" required>\n      <button type=\"submit\">Buscar</button>\n    </form>\n  </div>\n</body>\n</html>",
