    {
        "id": "c2098992715baead",
        "type": "function",
        "z": "779f94c568d26514",
        "name": "function 2",
        "func": "let data = msg.payload;\n\n\ntry {\n    if (typeof data === \"string\") {\n        data = JSON.parse(data);\n    }\n} catch (e) {\n    msg.cepErro = \"CEP não encontrado!\";\n    return msg;\n}\n\n\nif (!data || !data.cep) {\n    msg.cepErro = \"CEP não encontrado!\";\n    return msg;\n}\n\n\nmsg.cepData = {\n    cep: data.cep,\n    street: data.street || \"\",\n    neighborhood: data.neighborhood || \"\",\n    city: data.city || \"\",\n    state: data.state || \"\"\n};\n\nreturn msg;",
