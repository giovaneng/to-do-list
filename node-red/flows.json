        "func": "let lista = Array.isArray(msg.payload) ? msg.payload : [];\n\nlista = lista.slice(0, 20);\n\nmsg.corretoras = lista.map(c => {\n    return {\n        nome: c.nome_social || c.nome_comercial || \"Sem nome\",\n        cidade: c.municipio || \"Sem cidade\",\n        cnpj: c.cnpj || \"Sem CNPJ\"\n    };\n});\n\nreturn msg;",
