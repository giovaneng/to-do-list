        "id": "9cc83c97a0210845",
        "type": "function",
        "z": "779f94c568d26514",
        "name": "function 1",
        "func": "let cep = msg.req.query.cep || \"\";\ncep = cep.replace(/\\D/g, \"\");\n\nif (cep.length !== 8) {\n    msg.cepErro = \"CEP inválido! Digite um CEP com 8 números.\";\n    return [null, msg];\n}\n\nmsg.url = \"https://brasilapi.com.br/api/cep/v1/\" + cep;\nreturn [msg, null];",
